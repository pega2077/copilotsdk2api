{
  "name": "copilotsdk2api",
  "version": "1.0.0",
  "description": "OpenAI-compatible API service backed by GitHub Copilot SDK",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\""
  },
  "keywords": [
    "github",
    "copilot",
    "openai",
    "api",
    "sdk"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@github/copilot-sdk": "^0.1.8",
    "express": "^5.0.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/node": "^22.0.0",
    "@types/sharp": "^0.31.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.0.0"
  }
}
